. /lib/functions/uci-defaults.sh

board_config_update

board=$(board_name)

case "$board" in
mikrotik,routerboar-2011uias-2hnd)
	ucidef_add_gpio_switch "usb_power" "USB host power" "20" "1"
	ucidef_add_gpio_switch "poe_port10_out_power" "PoE outuput on port 10" "2" "0"
	;;
esac

board_config_flush

exit 0
